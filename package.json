{
    "name": "johannische-kirche-gesangbuch",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "vue-tsc && vite build",
        "build:prod": "cross-env NODE_ENV=production vue-tsc && vite build",
        "preview": "vite preview",
        "test:e2e": "cypress run",
        "test:unit": "vitest",
        "lint": "eslint .",
        "format": "prettier --write src/ --ignore-path dist/",
        "deploy": "pnpm run build:prod && wrangler pages deploy dist",
        "deploy:staging": "cross-env NODE_ENV=staging pnpm run build && wrangler pages deploy dist --branch staging",
        "wrangler:dev": "wrangler pages dev dist"
    },
    "dependencies": {
        "@capacitor/app": "8.1.0",
        "@capacitor/core": "8.3.4",
        "@capacitor/haptics": "8.0.2",
        "@capacitor/keyboard": "8.0.3",
        "@capacitor/status-bar": "8.0.2",
        "@directus/sdk": "^21.3.0",
        "@ionic/vue": "^8.8.8",
        "@ionic/vue-router": "^8.8.8",
        "abcjs": "^6.6.3",
        "dexie": "^4.4.3",
        "graphql": "^16.14.0",
        "ionicons": "^8.0.13",
        "opensheetmusicdisplay": "^1.9.9",
        "osmd-audio-player": "^0.7.0",
        "pinia": "^3.0.4",
        "vue": "^3.5.35",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@capacitor/cli": "8.3.4",
        "@eslint/js": "^10.0.1",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@vitejs/plugin-legacy": "^8.0.2",
        "@vitejs/plugin-vue": "^6.0.3",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/test-utils": "^2.4.10",
        "cross-env": "^10.1.0",
        "cypress": "^15.16.0",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-prettier-vue": "^5.0.0",
        "eslint-plugin-vue": "^10.9.1",
        "globals": "^17.6.0",
        "jsdom": "^29.1.1",
        "prettier": "^3.8.3",
        "terser": "^5.48.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "^8.0.14",
        "vite-plugin-pwa": "^1.3.0",
        "vite-plugin-vue-devtools": "^8.1.2",
        "vitest": "^4.1.7",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.3.2",
        "wrangler": "^4.95.0"
    },
    "description": "An Ionic project"
}
